## docs/sphinx/Makefile.am — build Sphinx docs only on demand

.PHONY: docs clean-docs

DOCS_SRC = .
DOCS_OUT = _build/html
## Directories/files generated by Sphinx that we want to purge on `make clean`
CLEAN_DIRS = _build

PYTHON ?= python3
SPHINX_MODULE_DOC ?= $(PYTHON) -m sphinx.ext.apidoc
MODULE_DOC_SRC = ../../src/gm_tools
MODULE_DOC_OUT = design/modules
MODULE_DOC_EXCLUDES = _config.py __init__.py

docs:
	@if test "x$(SPHINXBUILD)" = "x:"; then \
	  echo "sphinx-build not found; skipping Sphinx docs ($(DOCS_SRC))"; \
	else \
	  echo "Generating gm_tools API reStructuredText into $(MODULE_DOC_OUT)"; \
	  mkdir -p $(MODULE_DOC_OUT); \
	  $(SPHINX_MODULE_DOC) --force -o $(MODULE_DOC_OUT) $(MODULE_DOC_SRC) $(MODULE_DOC_EXCLUDES); \
	  echo "Building Sphinx HTML into $(DOCS_OUT)"; \
	  $(SPHINXBUILD) -b html $(DOCS_SRC) $(DOCS_OUT); \
	fi

clean-docs:
	rm -rf $(DOCS_OUT)

## Ensure `make clean` in this directory also removes Sphinx outputs
clean-local:
	rm -rf $(CLEAN_DIRS)
