# =====================================================================
# .gitattributes
# This file is derived from https://github.com/alexkaratarakis/gitattributes
#  - 改行/EOL を LF に強制 ( 混在やCRLF混入事故の防止 )
#  - バイナリ類は確実に -text / -diff ( 誤ったEOL変換や巨大差分を防止 )
#  - 生成物や開発補助系は export-ignore ( 配布アーカイブをクリーンに )
#  - 文字エンコーディングは UTF-8 を前提
# =====================================================================

# --- デフォルト方針: テキストは LF 前提 ---
*                text=auto eol=lf

# --- ドキュメント/テキスト ---
*.md             text eol=lf diff=markdown
*.mdx            text eol=lf diff=markdown
*.txt            text eol=lf
*.adoc           text eol=lf
*.rst            text eol=lf
*.csv            text
*.tab            text
*.tsv            text
*.sql            text
*.tex            text diff=tex
*.bibtex         text diff=bibtex
*.doc            diff=astextplain
*.DOC            diff=astextplain
*.docx           diff=astextplain
*.DOCX           diff=astextplain
*.dot            diff=astextplain
*.DOT            diff=astextplain
*.rtf            diff=astextplain
*.RTF            diff=astextplain
*.epub           diff=astextplain
*.mustache       text
*.textile        text

# --- スクリプト ---
