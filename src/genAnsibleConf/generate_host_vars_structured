"""generate_host_vars_structured の起動ラッパー。"""

from __future__ import annotations

import sys
import site

# configure の --prefix に対応した site-packages を動的に取得。
# これにより --prefix=/usr や --prefix=/opt/... 等の場合も対応可能。
# site.getsitepackages() は dist-packages のみを返すシステムもあるため、
# site-packages バージョンも登録する。

for sitedir in site.getsitepackages():
    if sitedir not in sys.path:
        sys.path.insert(0, sitedir)
    # dist-packages -> site-packages フォールバック
    fallback_path: str = sitedir.replace('/dist-packages', '/site-packages')
    if fallback_path != sitedir and fallback_path not in sys.path:
        sys.path.insert(0, fallback_path)

from genAnsibleConf.cli.generate_host_vars_structured import main


if __name__ == "__main__":
    sys.exit(main())