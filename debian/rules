#!/usr/bin/make -f

%:
	dh $@ --with python3

override_dh_auto_configure:
	./autogen.sh
	./configure PYTHON=python3 --prefix=/usr

override_dh_auto_build:
	$(MAKE)

override_dh_auto_install:
	dh_auto_install --destdir=$(CURDIR)/debian/tmp
	mkdir -p $(CURDIR)/debian/tmp/etc/genAnsibleConf
	cp -f config/genAnsibleConf.system-config.yaml \
	  $(CURDIR)/debian/tmp/etc/genAnsibleConf/config.yaml
	mkdir -p $(CURDIR)/debian/tmp/usr/share/genAnsibleConf/examples
	cp -f config/genAnsibleConf.user-config.yaml \
	  $(CURDIR)/debian/tmp/usr/share/genAnsibleConf/examples/genAnsibleConf.user-config.yaml

# 環境に依存するのでmake checkはスキップする
override_dh_auto_test:
	@echo "Skipping dh_auto_test: Step4/Step5 tests require sudo and external SSH hosts; run tests manually on real environment."
	@# no-op
	: